{
  "name": "@ayo-run/mnswpr",
  "version": "0.4.26",
  "description": "Classic Minesweeper browser game",
  "author": "Ayo",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayo-run/mnswpr"
  },
  "main": "dist/mnswpr.js",
  "scripts": {
    "test": "echo \"Warn: no test specified\"",
    "dev": "vite app",
    "start": "vite app",
    "build": "vite build app",
    "preview": "vite preview app",
    "build:preview": "npm run build && npm run preview",
    "build:lib": "vite build lib",
    "release": "bumpp && node scripts/release.js && npm publish",
    "build:release": "npm run build:lib && npm run release",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "exports": {
    ".": {
      "default": "./lib/dist/mnswpr.js"
    },
    "./*": {
      "default":"./lib/dist/*"
    }
  },
  "files": [
    "lib/dist",
    "README.md",
    "LICENSE"
  ],
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "simple-git": "^3.33.0",
    "vite": "^8.0.3"
  }
}
